APP_ENV=local
STORAGE_DIR=/app/storage
ADMIN_SETUP_TOKEN=

LLM_BASE_URL=http://host.docker.internal:8001/v1
LLM_API_KEY=replace-me
LLM_MODEL=your-chat-model

EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

NEMO_GUARDRAILS_ENABLED=true
NEMO_CONFIG_PATH=/app/configs/guardrails

ORACLE_DSN=oracle-host:1521/ORCLPDB1
ORACLE_USER=readonly_user
ORACLE_PASSWORD=replace-me
ORACLE_CURRENT_SCHEMA=
ORACLE_MODE=thin
ORACLE_CLIENT_LIB_DIR=/opt/oracle/instantclient

SQL_MAX_ROWS=100
SQL_TIMEOUT_SECONDS=30
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
